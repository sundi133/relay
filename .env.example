# ========================================================================
# Relay LLM Proxy Environment Variables
# ========================================================================
#
# Instructions:
#   1. Copy this file:        cp .env.example .env
#   2. Fill in your API keys: nano .env  (or your editor)
#   3. Restart relay:         ./start_relay.sh
#
# Security:
#   - Never commit .env to git (should be in .gitignore)
#   - Use strong, unique keys for production
#   - Rotate keys regularly
#
# Generate secure relay key:
#   openssl rand -base64 32
#
# ========================================================================

# ── RELAY AUTHENTICATION ──────────────────────────────────────────────
# Master key for relay proxy authentication
# Overrides config.yaml master_key if set
# Clients must send: Authorization: Bearer <this-key>
RELAY_KEY=sk-relay-your-secure-key-here

# Alternative name for compatibility (both work, RELAY_KEY takes priority)
RELAY_BEARER_TOKEN=sk-relay-secret-change-me

# ── CLOUD LLM PROVIDERS ───────────────────────────────────────────────
# Comment out providers you don't use

# OpenAI (gpt-4o, gpt-4o-mini, o1)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Anthropic (claude-sonnet, claude-opus)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (gemini-2.0-flash, gemini-1.5-pro)
GEMINI_API_KEY=your-gemini-key-here

# ── CHINESE LLM PROVIDERS ─────────────────────────────────────────────

# Qwen/Alibaba DashScope (qwen-turbo, qwen-plus, qwen-max)
DASHSCOPE_API_KEY=your-qwen-dashscope-api-key-here

# Zhipu AI (glm-4, glm-4-flash, glm-4v)
ZHIPU_API_KEY=your-glm-zhipu-api-key-here

# Moonshot AI (moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k)
MOONSHOT_API_KEY=your-kimi-moonshot-api-key-here

# DeepSeek (deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 01.AI (yi-lightning, yi-large)
YI_API_KEY=your-yi-key-here

# Baichuan (Baichuan4)
BAICHUAN_API_KEY=your-baichuan-key-here

# MiniMax (abab6.5-chat)
MINIMAX_API_KEY=your-minimax-key-here

# ── OTHER PROVIDERS ───────────────────────────────────────────────────

# Mistral AI (mistral-large-latest, codestral)
MISTRAL_API_KEY=your-mistral-key-here

# ── LOCAL/SELF-HOSTED ─────────────────────────────────────────────────
# These don't need API keys, but the services must be running

# Ollama (for llama3, qwen-local models)
# Start with: ollama serve
# Pull models: ollama pull llama3.2, ollama pull qwen2.5:7b
# Default URL: http://localhost:11434

# vLLM (for qwen-72b and other large models)
# Start with: vllm serve Qwen/Qwen2.5-72B-Instruct --port 8000
# Default URL: http://localhost:8000

# llama.cpp server
# Start with: ./server -m model.gguf --port 8080
# Default URL: http://localhost:8080

# Text Generation Inference (TGI)
# Start with: docker run -p 8080:80 huggingface/text-generation-inference
# Default URL: http://localhost:8080

# ── OPTIONAL: OVERRIDE PROVIDER URLS ──────────────────────────────────
# Uncomment to use custom endpoints (useful for proxies/load balancers)

# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── DEVELOPMENT/TESTING ───────────────────────────────────────────────
# Uncomment for development

# LOG_LEVEL=debug
# RELAY_WORKERS=1
# RELAY_TIMEOUT=60

# ── EXAMPLE USAGE ─────────────────────────────────────────────────────
#
# Test health:
#   curl http://localhost:4000/health
#
# List models:
#   curl -H "Authorization: Bearer sk-relay-your-secure-key-here" \
#        http://localhost:4000/v1/models
#
# Chat completion:
#   curl http://localhost:4000/v1/chat/completions \
#     -H "Content-Type: application/json" \
#     -H "Authorization: Bearer sk-relay-your-secure-key-here" \
#     -d '{
#       "model": "gpt-4o",
#       "messages": [{"role": "user", "content": "Hello!"}],
#       "max_tokens": 50
#     }'
#
# Streaming:
#   curl http://localhost:4000/v1/chat/completions \
#     -H "Content-Type: application/json" \
#     -H "Authorization: Bearer sk-relay-your-secure-key-here" \
#     -d '{
#       "model": "gpt-4o",
#       "messages": [{"role": "user", "content": "Count to 10"}],
#       "stream": true
#     }'
